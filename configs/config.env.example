# OTOBOSuite unattended installation configuration
# Copy to /etc/otobo-installer.conf and edit:
#
# Required:
FQDN=otobo.example.com
DB_ENGINE=mariadb
DB_NAME=otobo
DB_USER=otobo
DB_PASS=your_secure_password
ADMIN_USER=admin
ADMIN_PASS=your_admin_password
#
# Optional (shown with defaults):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# WEB_SERVER=apache
# OTOBO_ROOT=/opt/otobo
# OTOBO_USER=otobo
# OTOBO_GROUP=www-data
# SSL_MODE=none
# SSL_EMAIL=
# INSTALL_AI=no
# AI_MODEL=minilm
# AI_QUEUE=Raw
# AI_POLL_INTERVAL=60
# INSTALL_HARDENING=no
# INSTALL_MONITORING=no
# APT_REPO_URL=https://packages.example.com/apt
# APT_REPO_GPG_KEY_URL=https://packages.example.com/gpg.key
